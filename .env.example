# ---- Supabase ----
# Public URL and anon key are safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key is ONLY used by the ingestion script and server-side code.
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- Ingestion ----
# Comma-separated ticker list override. Leave blank to use lib/tickers.ts.
INGEST_TICKERS=

# Requests per second when pulling from Yahoo (be polite).
INGEST_RPS=2

# ---- App ----
NEXT_PUBLIC_APP_NAME="India Earnings Tracker"
NEXT_PUBLIC_DEFAULT_QUARTER="Q4 FY26"
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# ---- Cloudflare cache (optional — used after DNS migration) ----
# Token: Cloudflare dash → My Profile → API Tokens → Create Token.
# Permission: Zone → Cache Purge → Purge. Scoped to your zone only.
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Shared secret the ingestion scripts present when calling
# POST /api/cache-purge. Generate with `openssl rand -hex 32` and store
# the same value in both the Next deployment env and the ingestion env.
CACHE_PURGE_SECRET=
