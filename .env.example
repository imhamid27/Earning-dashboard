# ---- Supabase ----
# Public URL and anon key are safe for the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key is ONLY used by the ingestion script and server-side code.
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- Ingestion ----
# Comma-separated ticker list override. Leave blank to use lib/tickers.ts.
INGEST_TICKERS=

# Requests per second when pulling from Yahoo (be polite).
INGEST_RPS=2

# ---- App ----
NEXT_PUBLIC_APP_NAME="India Earnings Tracker"
NEXT_PUBLIC_DEFAULT_QUARTER="Q4 FY26"
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# ---- CloudFront cache (optional — used after CDN cutover) ----
# AWS CloudFront distribution ID for the dashboard. Find it at
# https://console.aws.amazon.com/cloudfront/v4/home → your distribution →
# "ID" column (looks like E1A2B3C4D5E6F7).
AWS_CLOUDFRONT_DISTRIBUTION_ID=

# AWS credentials for the CloudFront control-plane API. Create an IAM
# user/role with permission cloudfront:CreateInvalidation scoped to the
# distribution above, then drop its access key here. If the Next
# deployment runs on EC2 with an attached instance role, leave these
# blank — the SDK auto-discovers the role.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# CloudFront's control plane is global but the SDK pins us-east-1.
AWS_DEFAULT_REGION=us-east-1

# Shared secret the ingestion scripts present when calling
# POST /api/cache-purge. Generate with `openssl rand -hex 32` and store
# the same value in both the Next deployment env and the ingestion env.
CACHE_PURGE_SECRET=
